        0         fip1 = ctd.dynamics(tip1, xip1, uip1, v)
        - 
        -         # state equation
        0         if ctd.state_dimension == 1
        0             c[index] = xip1 - (xi + 0.5*h*(fi + fip1))            
        -         else
    61280             c[index:index+ctd.state_dimension-1] = xip1 - (xi + 0.5*h*(fi + fip1))
