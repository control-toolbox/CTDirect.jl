        - 
        0     index = 1 # counter for the constraints
    15696     for i in 0:N-1
    39824         tip1 = t0 + (i+1)*h
        -         
        -         # state and control at t_{i+1}
     7824         xip1 = get_state_at_time_step(xu, ctd, i+1)
     7824         uip1 = get_control_at_time_step(xu, ctd, i+1)
        -         #get_state_at_time_step!(xip1, xu, ctd, i+1)
