        -             xli = xlip1
        -             li = lip1
        -         end
    14640         index = index + ctd.dim_NLP_state
        - 
        -         # path constraints
        0         if ctd.has_control_constraints
    77280             c[index:index+ctd.dim_control_constraints-1] = ctd.control_constraints[2](ti, ui, v)
    14640             index = index + ctd.dim_control_constraints
        -         end
        0         if ctd.has_state_constraints
    77280             c[index:index+ctd.dim_state_constraints-1] = ctd.state_constraints[2](ti, xi ,v)
    14640             index = index + ctd.dim_state_constraints
