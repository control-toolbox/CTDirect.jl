        0     tf = get_final_time(xu, ctd)
        0     N = ctd.dim_NLP_steps
       32     h = (tf - t0) / N
        0     c = zeros(eltype(xu), ctd.dim_NLP_constraints)
        0     v = get_variable(xu, ctd)
