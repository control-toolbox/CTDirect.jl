        -     # state box
        -     offset = 0
        0     if ctd.has_state_box
        0         for i in 0:N
        0             for j in 1:ctd.dim_state_box
        0                 indice = ctd.state_box[2][j]
        0                 l_var[offset+indice] = ctd.state_box[1][j]
        0                 u_var[offset+indice] = ctd.state_box[3][j]
        0             end
        0             offset = offset + ctd.dim_NLP_state
        0         end
        -     end
        - 
        -     # control box
        0     offset = (N+1) * ctd.dim_NLP_state
        0     if ctd.has_control_box
        0         for i in 0:N
        0             for j in 1:ctd.dim_control_box
        0                 indice = ctd.control_box[2][j]
        0                 l_var[offset+indice] = ctd.control_box[1][j]
        0                 u_var[offset+indice] = ctd.control_box[3][j]
        0             end
        0             offset = offset + ctd.control_dimension
        0         end
        -     end
        - 
        -     # variable box
        0     offset = (N+1) * (ctd.dim_NLP_state + ctd.control_dimension)
        0     if ctd.has_variable_box
        0         for j in 1:ctd.dim_variable_box
        0             indice = ctd.variable_box[2][j]
        0             l_var[offset+indice] = ctd.variable_box[1][j]
        0             u_var[offset+indice] = ctd.variable_box[3][j]
        0         end
        -     end
        - 
        0     return l_var, u_var
        - end
